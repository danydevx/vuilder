<script setup>
import { computed, ref, onMounted } from 'vue'

const props = defineProps({
  id: { type: String, default: 'section-services' },
  scheme: { type: String, default: 'rose-light' },
  title: { type: String, default: 'Servicios' },
  intro: { type: String, default: '' },
  footnote: { type: String, default: '' },
  featuredServices: { type: Array, default: () => [] },
  otherServices: { type: Array, default: () => [] },
  otherTitle: { type: String, default: 'Otros servicios' },
  otherIntro: { type: String, default: '' },
  featuredColumnsMd: { type: Number, default: 2 },
  featuredColumnsLg: { type: Number, default: 3 },
  compactColumnsMd:  { type: Number, default: 3 },
  compactColumnsLg:  { type: Number, default: 4 },
  backgroundImg: { type: String, default: '' },
  enableOverlay: { type: Boolean, default: false }
})

const emit = defineEmits(['cta:click'])

const schemeClass = computed(() => `scheme-${props.scheme}`)
const featuredColClass = computed(() => props.featuredColumnsMd === 3 ? 'col-md-4' : 'col-md-6')
const compactColClass = computed(() => `col-md-${12 / props.compactColumnsMd} col-lg-${12 / props.compactColumnsLg}`)

const KEYWORD_ICON_MAP = [
  { keys: ['asador','parrilla','grill','bbq'], icon: 'bi bi-fire' },
  { keys: ['estacionamiento','parking','aparcamiento','auto'], icon: 'bi bi-car-front' },
  { keys: ['baño','banos','baños','toilet','restroom','wc'], icon: 'bi bi-droplet' },
  { keys: ['wifi','internet'], icon: 'bi bi-wifi' },
  { keys: ['musica','música','music','audio'], icon: 'bi bi-music-note-beamed' },
  { keys: ['iluminacion','iluminación','luces','lighting'], icon: 'bi bi-lightbulb' },
  { keys: ['sombra','toldo','carpa'], icon: 'bi bi-umbrella' },
  { keys: ['seguridad','security'], icon: 'bi bi-shield-check' },
  { keys: ['jardin','jardín','garden'], icon: 'bi bi-tree' },
  { keys: ['cocina','cocineta','kitchen'], icon: 'bi bi-basket' },
  { keys: ['bar','bebidas','drinks'], icon: 'bi bi-cup-hot' },
  { keys: ['electricidad','power','energia'], icon: 'bi bi-lightning' },
  { keys: ['clima','aire','ac'], icon: 'bi bi-thermometer-sun' },
  { keys: ['vista','mirador','view'], icon: 'bi bi-binoculars' }
]
const DEFAULT_ICON = 'bi bi-gear'
const resolveIcon = (svc) => {
  if (svc?.icon) return svc.icon
  const hay = (svc?.title || '') + ' ' + (svc?.subtitle || '') + ' ' + (svc?.text || '')
  return (KEYWORD_ICON_MAP.find(m => m.keys.some(k => hay.toLowerCase().includes(k)))?.icon) || DEFAULT_ICON
}

const modalEl = ref(null)
const modalInstance = ref(null)
const activeSvc = ref(null)
const modalId = computed(() => `${props.id}-modal`)

onMounted(() => {
  if (window.bootstrap?.Modal && modalEl.value) {
    modalInstance.value = new window.bootstrap.Modal(modalEl.value, { backdrop: true, keyboard: true })
  }
})

const openModal = (svc) => {
  activeSvc.value = svc
  modalInstance.value?.show()
}
const closeModal = () => modalInstance.value?.hide()

const buttonClass = (cta) => {
  const v = cta?.variant || 'solid'
  if (v === 'outline') return 'btn-outline-secondary'
  if (v === 'ghost') return 'btn-link btn-ghost'
  return 'btn-primary btn-scheme'
}
const onCta = (svc, cta) => {
  emit('cta:click', { service: svc, cta })
  if (cta?.href?.startsWith('#')) {
    document.querySelector(cta.href)?.scrollIntoView({ behavior: 'smooth', block: 'start' })
  } else if (cta?.href) {
    window.location.href = cta.href
  }
}
</script>

