{
  "compilerOptions": {
    "baseUrl":"./",
     "paths": {
      "@/*": ["src/*"],
      "@assets/*": ["src/assets/*"],
      "@styles/*": ["src/styles/*"],
      "@components/*": ["src/components/*"],
      "@sections/*": ["src/sections/*"],
      "@partials/*": ["src/partials/*"],
      "@pages/*": ["src/pages/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
